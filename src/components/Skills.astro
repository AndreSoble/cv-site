---
import { skills } from '../data/skills';
---

<section id="skills" class="max-w-[1100px] mx-auto px-10 pb-24">
  <div class="flex items-center gap-3 mb-12">
    <span class="font-mono text-[11px] text-accent uppercase tracking-[0.1em]">Skills</span>
    <div class="flex-1 h-px bg-border"></div>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
    {skills.map(group => (
      <div>
        <div class="font-mono text-[11px] text-accent uppercase tracking-[0.1em] mb-3">
          {group.name}
        </div>
        <div class="text-sm text-ink leading-[1.9]">
          {group.items.join(' · ')}
        </div>
      </div>
    ))}
  </div>
</section>
