---
import { research } from '../data/research';
import { deResearch } from '../i18n/de';
import AnimatedSection from './AnimatedSection';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="research" class="max-w-[1100px] mx-auto px-10 pb-24">
  <div class="flex items-center gap-3 mb-12">
    <span class="font-mono text-[11px] text-accent uppercase tracking-[0.1em]">
      <span data-lang="en">Research &amp; Works</span>
      <span data-lang="de">Forschung &amp; Publikationen</span>
    </span>
    <div class="flex-1 h-px bg-border"></div>
  </div>

  <div class="flex flex-col">
    {research.map((item, i) => (
      <AnimatedSection delay={i * 0.08} client:visible>
        <div class="grid grid-cols-1 md:grid-cols-[80px_1fr] gap-6 items-start
                    py-7 border-t border-border last:border-b">
          <div class="font-mono text-xs text-muted pt-1">{item.year}</div>
          <div>
            <div class="font-mono text-[10px] text-accent uppercase tracking-[0.1em] mb-1.5">
              <span data-lang="en">{item.type}</span>
              <span data-lang="de">{deResearch[i].type}</span>
            </div>
            <div class="font-serif text-lg font-normal tracking-[-0.01em] leading-snug mb-2">
              {item.titleDE ? (
                <>
                  <span data-lang="en">{item.title}</span>
                  <span data-lang="de">{item.titleDE}</span>
                </>
              ) : item.title}
            </div>
            <div data-lang="en">
              <p class="text-sm text-muted leading-relaxed line-clamp-2 mb-3">
                {item.abstract}
              </p>
            </div>
            <div data-lang="de">
              <p class="text-sm text-muted leading-relaxed line-clamp-2 mb-3">
                {deResearch[i].abstract}
              </p>
            </div>
            <div class="flex flex-wrap gap-1.5 mb-3">
              {item.tech.map(t => (
                <span class="font-mono text-[10px] px-2 py-0.5 rounded border border-border bg-surface text-muted">
                  {t}
                </span>
              ))}
            </div>
            <div class="flex items-center gap-3">
              <button
                class="font-mono text-[11px] text-accent hover:opacity-70 transition-opacity cursor-pointer bg-transparent border-none p-0 hidden md:block"
                onclick={`window.openPdfModal('${base}${item.pdfPath}', '${item.title.replace(/'/g, "\\'")}')`}
                aria-label={`Preview: ${item.title}`}
              >
                <span data-lang="en">Preview ↗</span>
                <span data-lang="de">Vorschau ↗</span>
              </button>
              <span class="font-mono text-[11px] text-border hidden md:block">·</span>
              <a
                href={base + item.pdfPath}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Open PDF: ${item.title} (opens in new tab)`}
                class="font-mono text-[11px] text-accent hover:opacity-70 transition-opacity"
              >
                PDF ↗
              </a>
              {item.links?.map(link => (
                <>
                  <span class="font-mono text-[11px] text-border">·</span>
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${link.label}: ${item.title} (opens in new tab)`}
                    class="font-mono text-[11px] text-accent hover:opacity-70 transition-opacity"
                  >
                    {link.labelDE ? (
                      <>
                        <span data-lang="en">{link.label} ↗</span>
                        <span data-lang="de">{link.labelDE} ↗</span>
                      </>
                    ) : `${link.label} ↗`}
                  </a>
                </>
              ))}
            </div>
          </div>
        </div>
      </AnimatedSection>
    ))}
  </div>
</section>
