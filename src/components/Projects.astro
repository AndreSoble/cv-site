---
import { projects } from '../data/projects';
import { deProjects } from '../i18n/de';
import AnimatedSection from './AnimatedSection';
---

<section id="projects" class="max-w-[1100px] mx-auto px-10 pb-24">
  <div class="flex items-center gap-3 mb-12">
    <span class="font-mono text-[11px] text-accent uppercase tracking-[0.1em]">Open Source</span>
    <div class="flex-1 h-px bg-border"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-border border border-border rounded-xl overflow-hidden">
    {projects.map((project, i) => (
      <AnimatedSection delay={i * 0.08} client:visible className="h-full">
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${project.name} on GitHub (opens in new tab)`}
          class="flex flex-col h-full p-6 bg-bg hover:bg-surface transition-colors group"
          style="text-decoration: none;"
        >
          <div class="flex items-center justify-between mb-2">
            <span class="font-mono text-sm font-medium text-ink">{project.name}</span>
            <span class="font-mono text-xs text-muted group-hover:text-ink transition-colors">↗</span>
          </div>
          <div class="text-sm text-muted leading-relaxed mb-4 flex-1">
            <span data-lang="en">{project.description}</span>
            <span data-lang="de">{deProjects[i]}</span>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {project.tech.map(t => (
              <span class="font-mono text-[10px] px-2 py-0.5 rounded border border-border bg-bg text-muted">
                {t}
              </span>
            ))}
          </div>
        </a>
      </AnimatedSection>
    ))}
  </div>
</section>
