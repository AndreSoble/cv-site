---
import { experience } from '../data/experience';
import { deExperience } from '../i18n/de';
import AnimatedSection from './AnimatedSection';
---

<section id="experience" class="max-w-[1100px] mx-auto px-10 py-24">
  <div class="flex items-center gap-3 mb-12">
    <span class="font-mono text-[11px] text-accent uppercase tracking-[0.1em]">
      <span data-lang="en">Experience</span>
      <span data-lang="de">Berufserfahrung</span>
    </span>
    <div class="flex-1 h-px bg-border"></div>
  </div>

  <div class="flex flex-col">
    {experience.map((item, i) => (
      <AnimatedSection delay={i * 0.1} client:visible>
        <div class="grid grid-cols-1 md:grid-cols-[160px_1fr] gap-6 py-8 border-t border-border last:border-b">
          <div class="pt-0.5">
            <div class="font-mono text-xs text-muted">{item.period}</div>
            <div class="text-sm text-muted mt-1">{item.company}</div>
          </div>
          <div>
            <div class="font-serif text-[22px] font-normal tracking-[-0.02em] mb-2.5">
              {item.role}
            </div>

            {/* English bullets */}
            <div data-lang="en">
              <ul class="text-sm text-muted leading-relaxed space-y-0 mb-3.5">
                {item.description.map((bullet) => (
                  bullet.detail ? (
                    <li class="exp-bullet group relative pl-4 py-[3px] -mx-1 px-1 rounded">
                      <span class="bullet-dot absolute left-[5px] top-[10px] text-border">·</span>
                      <div class="flex items-baseline gap-1.5">
                        <span class="bullet-text flex-1">{bullet.text}</span>
                        <span class="bullet-hint font-mono text-[14px] text-muted flex-shrink-0 transition-all duration-200 leading-none select-none">+</span>
                      </div>
                      <div class="bullet-detail">
                        <div class="overflow-hidden">
                          <ul class="mt-[5px] mb-[2px] space-y-[2px]">
                            {bullet.detail.map((item: string) => (
                              <li class="flex gap-2 text-[12px] text-muted leading-relaxed">
                                <span class="text-border flex-shrink-0 mt-[3px]">–</span>
                                <span class="opacity-80">{item}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </li>
                  ) : (
                    <li class="relative pl-4 py-[3px]">
                      <span class="absolute left-[5px] top-[10px] text-border">·</span>
                      {bullet.text}
                    </li>
                  )
                ))}
              </ul>
            </div>

            {/* German bullets */}
            <div data-lang="de">
              <ul class="text-sm text-muted leading-relaxed space-y-0 mb-3.5">
                {deExperience[i].description.map((bullet) => (
                  bullet.detail ? (
                    <li class="exp-bullet group relative pl-4 py-[3px] -mx-1 px-1 rounded">
                      <span class="bullet-dot absolute left-[5px] top-[10px] text-border">·</span>
                      <div class="flex items-baseline gap-1.5">
                        <span class="bullet-text flex-1">{bullet.text}</span>
                        <span class="bullet-hint font-mono text-[14px] text-muted flex-shrink-0 transition-all duration-200 leading-none select-none">+</span>
                      </div>
                      <div class="bullet-detail">
                        <div class="overflow-hidden">
                          <ul class="mt-[5px] mb-[2px] space-y-[2px]">
                            {bullet.detail.map((item: string) => (
                              <li class="flex gap-2 text-[12px] text-muted leading-relaxed">
                                <span class="text-border flex-shrink-0 mt-[3px]">–</span>
                                <span class="opacity-80">{item}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </li>
                  ) : (
                    <li class="relative pl-4 py-[3px]">
                      <span class="absolute left-[5px] top-[10px] text-border">·</span>
                      {bullet.text}
                    </li>
                  )
                ))}
              </ul>
            </div>

            <div class="flex flex-wrap gap-1.5">
              {item.tags.map(tag => (
                <span class="font-mono text-[11px] px-2 py-0.5 rounded border border-border bg-surface text-muted">
                  {tag}
                </span>
              ))}
            </div>
            {item.links && (
              <div class="flex flex-wrap gap-2 mt-3">
                {item.links.map(link => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-mono text-[11px] text-accent hover:underline"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </AnimatedSection>
    ))}
  </div>
</section>

<style>
  .exp-bullet .bullet-detail {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .exp-bullet.open .bullet-detail {
    grid-template-rows: 1fr;
  }
  .exp-bullet.open .bullet-hint {
    color: var(--color-accent, #c4622d);
  }
  @media (hover: hover) {
    .exp-bullet:hover {
      background: rgba(20,18,16,0.03);
      border-radius: 4px;
    }
    .exp-bullet:hover .bullet-hint {
      color: var(--color-accent, #c4622d);
    }
  }
</style>

<script>
  document.querySelectorAll('.exp-bullet').forEach(li => {
    li.addEventListener('click', () => {
      const isOpen = li.classList.toggle('open');
      const hint = li.querySelector('.bullet-hint');
      if (hint) hint.textContent = isOpen ? '−' : '+';
    });
  });
</script>
