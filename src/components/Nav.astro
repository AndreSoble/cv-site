---
const links = [
  { href: '#experience', en: 'exp',      de: 'exp'       },
  { href: '#skills',     en: 'skills',   de: 'skills'    },
  { href: '#research',   en: 'research', de: 'forschung' },
  { href: '#projects',   en: 'projects', de: 'projekte'  },
  { href: '#contact',    en: 'contact',  de: 'kontakt'   },
];
---

<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-10 h-14
         bg-bg/85 backdrop-blur-md border-b border-border"
>
  <span class="font-mono text-sm text-muted flex items-center">
    André<span class="text-accent">.</span><span
      id="nav-suffix"
      class="inline-block overflow-hidden h-[1.2em] leading-[1.2em]"
    ><span id="nav-suffix-inner" class="block">ai</span></span>
  </span>

  <!-- Desktop links + language toggle -->
  <div class="hidden md:flex items-center gap-7">
    {links.map(({ href, en, de }) => (
      <a
        href={href}
        class="font-mono text-xs text-muted hover:text-ink transition-colors"
      >
        <span data-lang="en">{en}</span>
        <span data-lang="de">{de}</span>
      </a>
    ))}
    <button
      id="lang-toggle"
      aria-label="Toggle language"
      class="font-mono text-xs text-muted hover:text-ink transition-colors
             border border-border px-2 py-0.5 rounded ml-1"
    >
      <span data-lang="en">DE</span>
      <span data-lang="de">EN</span>
    </button>
  </div>

  <!-- Mobile hamburger -->
  <button
    id="menu-toggle"
    aria-label="Open navigation menu"
    class="md:hidden flex flex-col gap-1.5 p-2"
  >
    <span class="block w-5 h-px bg-ink"></span>
    <span class="block w-5 h-px bg-ink"></span>
    <span class="block w-5 h-px bg-ink"></span>
  </button>
</nav>

<!-- Mobile overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-bg flex flex-col items-center justify-center gap-8 hidden"
>
  {links.map(({ href, en, de }) => (
    <a
      href={href}
      class="font-mono text-2xl text-ink hover:text-accent transition-colors mobile-link"
    >
      <span data-lang="en">{en}</span>
      <span data-lang="de">{de}</span>
    </a>
  ))}
  <button
    id="lang-toggle-mobile"
    aria-label="Toggle language"
    class="font-mono text-base text-muted hover:text-ink transition-colors
           border border-border px-3 py-1 rounded mt-4"
  >
    <span data-lang="en">DE</span>
    <span data-lang="de">EN</span>
  </button>
</div>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;

  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    toggle.setAttribute('aria-label',
      menu.classList.contains('hidden') ? 'Open navigation menu' : 'Close navigation menu'
    );
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => menu.classList.add('hidden'));
  });

  // Cycling suffix
  const suffixes = ['ai', 'dev', 'ml', 'ops'];
  let idx = 0;
  const inner = document.getElementById('nav-suffix-inner')!;

  setInterval(() => {
    idx = (idx + 1) % suffixes.length;
    inner.style.animation = 'none';
    inner.style.animation = 'suffix-out 0.25s ease forwards';
    setTimeout(() => {
      inner.textContent = suffixes[idx];
      inner.style.animation = 'suffix-in 0.25s ease forwards';
    }, 250);
  }, 2500);
</script>

<style>
  @keyframes suffix-out {
    from { transform: translateY(0);     opacity: 1; }
    to   { transform: translateY(-110%); opacity: 0; }
  }
  @keyframes suffix-in {
    from { transform: translateY(110%);  opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }
</style>
